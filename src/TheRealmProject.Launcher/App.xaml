<Application x:Class="TheRealmProject.Launcher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#111318" />
        <SolidColorBrush x:Key="PanelBrush" Color="#1B1F27" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2DAA7D" />
        <SolidColorBrush x:Key="TextBrush" Color="#F3F6F4" />
        <SolidColorBrush x:Key="MutedBrush" Color="#A8B0AD" />
    </Application.Resources>
</Application>
