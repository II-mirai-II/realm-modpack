<Window x:Class="TheRealmProject.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:media3D="clr-namespace:System.Windows.Media.Media3D;assembly=PresentationCore"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="The Realm Project"
        Height="760"
        Width="1160"
        MinHeight="680"
        MinWidth="980"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent"
        Foreground="#F6F8F7">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#121820" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#0E141B" />
        <SolidColorBrush x:Key="InputBrush" Color="#080D13" />
        <SolidColorBrush x:Key="InputHoverBrush" Color="#111B25" />
        <SolidColorBrush x:Key="LineBrush" Color="#263241" />
        <SolidColorBrush x:Key="AccentBrush" Color="#26C994" />
        <SolidColorBrush x:Key="GoldBrush" Color="#E8BB4E" />
        <SolidColorBrush x:Key="BlueBrush" Color="#5AA4FF" />
        <SolidColorBrush x:Key="DangerBrush" Color="#D95F6A" />
        <SolidColorBrush x:Key="TextBrush" Color="#F6F8F7" />
        <SolidColorBrush x:Key="MutedBrush" Color="#A7B3AF" />

        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,7" />
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Background" Value="#1A2430" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#223142" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource BlueBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#172332" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#04130E" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style x:Key="PlayButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="MinHeight" Value="56" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Background" Value="{StaticResource GoldBrush}" />
            <Setter Property="Foreground" Value="#191104" />
            <Setter Property="BorderBrush" Value="{StaticResource GoldBrush}" />
        </Style>

        <Style x:Key="WindowCaptionButton" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#182330" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#101923" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowCloseButton" TargetType="Button" BasedOn="{StaticResource WindowCaptionButton}">
            <Setter Property="Foreground" Value="#E8A6A6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#C9434D" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#9F2F38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Padding" Value="22,10" />
            <Setter Property="MinWidth" Value="126" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Background" Value="#101721" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#162333" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource BlueBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#0E1824" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActiveNavButton" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="#123327" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="MinHeight" Value="36" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#1A3042" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#164A38" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Chrome"
                                                Background="{StaticResource InputBrush}"
                                                BorderBrush="{StaticResource LineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="38" />
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1"
                                                      Width="10"
                                                      Height="6"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Fill="{StaticResource MutedBrush}"
                                                      Data="M 0 0 L 10 0 L 5 6 Z" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource InputHoverBrush}" />
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource BlueBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="12,0,38,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="{StaticResource InputBrush}"
                                        BorderBrush="{StaticResource BlueBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="320">
                                    <ScrollViewer Margin="3" CanContentScroll="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="InstalledListBox" TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="ConsoleTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="MinHeight" Value="0" />
        </Style>

        <DataTemplate x:Key="InstalledVersionItemTemplate">
            <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding DisplayName}"
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,12,0" />
                    <Button Grid.Column="1"
                            Content="Desinstalar"
                            Style="{StaticResource BaseButton}"
                            MinHeight="30"
                            Height="30"
                            Padding="10,2"
                            BorderBrush="{StaticResource DangerBrush}"
                            Click="UninstallVersionButton_OnClick" />
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border x:Name="WindowFrame" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Background="#090D12" CornerRadius="14" ClipToBounds="True">
        <Grid>
        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown" Margin="0,8,146,0">
                <TextBlock Text="The Realm Project" FontSize="32" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,16,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="PlayTabButton" Content="Jogar" Style="{StaticResource ActiveNavButton}" Margin="0,0,12,0" Click="PlayTabButton_OnClick" />
                    <Button x:Name="CustomizationTabButton" Content="Customização" Style="{StaticResource NavButton}" Click="CustomizationTabButton_OnClick" />
                </StackPanel>
                <Border Grid.Column="1" Style="{StaticResource Card}" Padding="12,8" Margin="18,0,0,0" HorizontalAlignment="Stretch">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Instância" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock x:Name="PathText" Grid.Column="1" Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis" Margin="14,0,0,0" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                        </Grid>
                        <Button Content="Abrir Pasta Local" Style="{StaticResource BaseButton}" Height="34" MinHeight="34" Padding="12,4" Margin="0,8,0,0" HorizontalAlignment="Right" Click="OpenMinecraftFolderButton_OnClick" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2">
                <Grid x:Name="PlayContent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.58*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" MinHeight="170" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,18,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                <Label Content="Minecraft" />
                                <ComboBox x:Name="MinecraftVersionCombo" SelectionChanged="MinecraftVersionCombo_OnSelectionChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,14,0">
                                <Label Content="NeoForge" />
                                <ComboBox x:Name="NeoForgeVersionCombo" DisplayMemberPath="NeoForgeVersionId" />
                            </StackPanel>
                            <Button Grid.Column="2" x:Name="InstallButton" Content="Instalar" Style="{StaticResource BaseButton}" Width="124" VerticalAlignment="Bottom" Click="InstallButton_OnClick" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="4" Style="{StaticResource Card}" Background="{StaticResource PanelAltBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Versões Instaladas" Style="{StaticResource CardTitle}" />
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <Border Background="{StaticResource InputBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Minecraft" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,8" />
                                        <ListBox x:Name="InstalledMinecraftVersionsList"
                                                 Grid.Row="1"
                                                 Style="{StaticResource InstalledListBox}"
                                                 ItemTemplate="{StaticResource InstalledVersionItemTemplate}" />
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1" Background="{StaticResource InputBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="8,0,0,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="NeoForge" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,8" />
                                        <ListBox x:Name="InstalledNeoForgeVersionsList"
                                                 Grid.Row="1"
                                                 Style="{StaticResource InstalledListBox}"
                                                 ItemTemplate="{StaticResource InstalledVersionItemTemplate}" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}" Padding="18" Margin="0,0,18,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Selecione uma versão antes de pressionar em Jogar." Style="{StaticResource CardTitle}" TextWrapping="Wrap" Margin="0,0,0,6" />
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="RAM" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                    <Slider x:Name="RamSlider" Grid.Column="1" Minimum="1024" Maximum="8192" TickFrequency="512" IsSnapToTickEnabled="True" ValueChanged="RamSlider_OnValueChanged" />
                                    <TextBlock x:Name="RamValueText" Grid.Column="2" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="12,0,0,0" Width="70" />
                                </Grid>
                                <TextBlock x:Name="VersionStatusText" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="PlayButton" Content="Jogar" Style="{StaticResource PlayButtonStyle}" Width="150" Margin="18,0,0,0" Click="PlayButton_OnClick" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource Card}" Padding="18,14" Margin="0,0,18,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Modpack" Style="{StaticResource CardTitle}" Margin="0" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="DownloadModpackButton" Content="Download Realm Modpack" Style="{StaticResource PrimaryButton}" Width="230" Margin="0,0,10,0" Click="DownloadModpackButton_OnClick" />
                                <Button x:Name="UpdateModpackButton" Content="Atualizar" Style="{StaticResource BaseButton}" Width="124" Click="UpdateModpackButton_OnClick" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource Card}" Background="{StaticResource PanelAltBrush}" Padding="14" Margin="0,0,18,0" MinHeight="170">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Status" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBox x:Name="LogTextBox" Grid.Row="1" Style="{StaticResource ConsoleTextBox}" />
                        </Grid>
                    </Border>
                </Grid>

                <Grid x:Name="CustomizationContent" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.35*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,18,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="Seu Nick" Style="{StaticResource CardTitle}" />
                                <TextBox x:Name="PlayerIdTextBox" MaxLength="16" MaxWidth="360" HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Cosméticos" Style="{StaticResource CardTitle}" />
                                <Label Content="Skin PNG" />
                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="SkinPathTextBox" IsReadOnly="True" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                                    <Button Grid.Column="1" Content="Selecionar" Style="{StaticResource BaseButton}" Width="120" Margin="12,0,0,0" Click="SelectSkinButton_OnClick" />
                                </Grid>

                                <Label Content="Capa PNG" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="CapePathTextBox" IsReadOnly="True" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                                    <Button Grid.Column="1" Content="Selecionar" Style="{StaticResource BaseButton}" Width="120" Margin="12,0,0,0" Click="SelectCapeButton_OnClick" />
                                </Grid>

                                <Button x:Name="SaveProfileButton" Content="Salvar Customização" Style="{StaticResource PrimaryButton}" Width="210" Margin="0,24,0,0" Click="SaveProfileButton_OnClick" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Column="1" Style="{StaticResource Card}" Background="{StaticResource PanelAltBrush}">
                        <StackPanel>
                            <TextBlock Text="Preview" Style="{StaticResource CardTitle}" />
                            <Border Background="{StaticResource InputBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="10" Width="340" Height="420" HorizontalAlignment="Left" ClipToBounds="True">
                                <Grid>
                                    <Viewport3D x:Name="SkinPreviewViewport"
                                                Margin="12"
                                                ClipToBounds="True"
                                                MouseLeftButtonDown="SkinPreviewViewport_OnMouseLeftButtonDown"
                                                MouseLeftButtonUp="SkinPreviewViewport_OnMouseLeftButtonUp"
                                                MouseMove="SkinPreviewViewport_OnMouseMove"
                                                MouseWheel="SkinPreviewViewport_OnMouseWheel">
                                        <Viewport3D.Camera>
                                            <PerspectiveCamera x:Name="SkinPreviewCamera"
                                                               Position="0,16,62"
                                                               LookDirection="0,0,-62"
                                                               UpDirection="0,1,0"
                                                               FieldOfView="28" />
                                        </Viewport3D.Camera>
                                        <ModelVisual3D>
                                            <ModelVisual3D.Content>
                                                <AmbientLight Color="#626A70" />
                                            </ModelVisual3D.Content>
                                        </ModelVisual3D>
                                        <ModelVisual3D>
                                            <ModelVisual3D.Content>
                                                <DirectionalLight Color="#FFFFFF" Direction="-0.4,-0.65,-1" />
                                            </ModelVisual3D.Content>
                                        </ModelVisual3D>
                                        <ModelVisual3D>
                                            <ModelVisual3D.Content>
                                                <DirectionalLight Color="#8797A8" Direction="0.7,0.25,0.8" />
                                            </ModelVisual3D.Content>
                                        </ModelVisual3D>
                                        <ModelVisual3D x:Name="SkinPreviewModelVisual" />
                                    </Viewport3D>
                                    <Image x:Name="SkinPreview" Visibility="Collapsed" />
                                    <TextBlock x:Name="SkinPreviewPlaceholder"
                                               Text="Preview"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
        <StackPanel Panel.ZIndex="10" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,6,6,0">
            <Button Style="{StaticResource WindowCaptionButton}" Click="MinimizeButton_OnClick" ToolTip="Minimizar">
                <Path Width="12" Height="1.6" Stretch="Fill" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Data="M 0 0 L 12 0 L 12 1.6 L 0 1.6 Z" />
            </Button>
            <Button x:Name="MaximizeButton" Style="{StaticResource WindowCaptionButton}" Click="MaximizeButton_OnClick" ToolTip="Maximizar">
                <Grid Width="14" Height="14">
                    <Path x:Name="MaximizeIcon" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Data="M 2 2 H 12 V 12 H 2 Z" />
                    <Path x:Name="RestoreIcon" Visibility="Collapsed" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Data="M 5 2 H 12 V 9 M 2 5 H 9 V 12 H 2 Z" />
                </Grid>
            </Button>
            <Button Style="{StaticResource WindowCloseButton}" Click="CloseButton_OnClick" ToolTip="Fechar">
                <Path Width="12" Height="12" Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M 1 1 L 11 11 M 11 1 L 1 11" />
            </Button>
        </StackPanel>
        </Grid>
    </Border>
</Window>
